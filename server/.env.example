PORT=4000
NODE_ENV=production
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://luneboutiquedanang.id.vn,https://www.luneboutiquedanang.id.vn,https://luneboutiquedanang.com,https://www.luneboutiquedanang.com
SOCKET_CORS_ORIGIN=https://luneboutiquedanang.id.vn,https://www.luneboutiquedanang.id.vn,https://luneboutiquedanang.com,https://www.luneboutiquedanang.com
BCRYPT_SALT_ROUNDS=10
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
CURRENCY_PROVIDER=frankfurter
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1

# Bluejay/PMS API v2 integration.
# Keep real API tokens only in backend environment variables.
BLUEJAY_ENABLED=false
BLUEJAY_CREATE_BOOKING_ENABLED=false
BLUEJAY_API_BASE_URL=https://api-pms.bluejaypms.com/api/v2
BLUEJAY_AVAILABILITY_PATH=/search-roomtypes
BLUEJAY_AVAILABILITY_METHOD=GET
BLUEJAY_API_TOKEN=
BLUEJAY_AUTH_HEADER_NAME=ApiKey
BLUEJAY_AUTH_HEADER_PREFIX=none
BLUEJAY_PROPERTY_ID=6439
BLUEJAY_CHANNEL_CODE=
BLUEJAY_ROOM_MAPPING_JSON={"one-bedroom-condo":"12666","one-bedroom-apartment-balcony":"12663","two-bedroom-apartment":"12665","studio-two-bed-balcony":"12664","two-bedroom-apartment-balcony":"12662"}
BLUEJAY_RATEPLAN_MAPPING_JSON={}
BLUEJAY_USER_AGENT=WebLuneBluejayAdapter/1.0
BLUEJAY_TIMEOUT_MS=10000
BLUEJAY_FAIL_CLOSED=true

# PayOS QR payment integration.
# Keep these values only in backend environment variables. Never expose them in frontend code.
PAYOS_ENABLED=false
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=https://www.luneboutiquedanang.com/success
PAYOS_CANCEL_URL=https://www.luneboutiquedanang.com/payment
PAYOS_WEBHOOK_URL=https://your-backend-domain.com/api/webhooks/payment/payos
PAYOS_TIMEOUT_MS=15000

# Phone OTP verification for public bookings.
# Set PHONE_OTP_REQUIRED=true only after a real SMS provider is configured.
PHONE_OTP_ENABLED=false
PHONE_OTP_REQUIRED=false
PHONE_OTP_TTL_MINUTES=5
PHONE_OTP_RESEND_SECONDS=60
PHONE_OTP_MAX_ATTEMPTS=5
PHONE_OTP_RATE_LIMIT_WINDOW_MINUTES=30
PHONE_OTP_RATE_LIMIT_MAX=5
PHONE_OTP_DEBUG_RESPONSE=false

# SMS_PROVIDER can be webhook or twilio in production. Use log only for local development.
SMS_PROVIDER=
SMS_WEBHOOK_URL=
SMS_WEBHOOK_AUTH_HEADER=
SMS_WEBHOOK_AUTH_VALUE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
