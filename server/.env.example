PORT=4000
NODE_ENV=production
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://luneboutiquedanang.id.vn,https://www.luneboutiquedanang.id.vn
SOCKET_CORS_ORIGIN=https://luneboutiquedanang.id.vn,https://www.luneboutiquedanang.id.vn
BCRYPT_SALT_ROUNDS=10
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
CURRENCY_PROVIDER=frankfurter
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1

# Bluejay/PMS availability integration.
# Keep real API tokens only in backend environment variables.
BLUEJAY_ENABLED=false
BLUEJAY_API_BASE_URL=
BLUEJAY_AVAILABILITY_PATH=/availability
BLUEJAY_AVAILABILITY_METHOD=POST
BLUEJAY_API_TOKEN=
BLUEJAY_AUTH_HEADER_NAME=Authorization
BLUEJAY_AUTH_HEADER_PREFIX=Bearer
BLUEJAY_PROPERTY_ID=
BLUEJAY_ROOM_MAPPING_JSON={"deluxe-studio":"BLUEJAY_ROOM_ID_1","superior-apartment":"BLUEJAY_ROOM_ID_2","family-apartment":"BLUEJAY_ROOM_ID_3","long-stay-apartment":"BLUEJAY_ROOM_ID_4","type-3-kitchen-apartment":"BLUEJAY_ROOM_ID_5"}
BLUEJAY_TIMEOUT_MS=6000
BLUEJAY_FAIL_CLOSED=true

# PayOS QR payment integration.
# Keep these values only in backend environment variables. Never expose them in frontend code.
PAYOS_ENABLED=false
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=https://luneboutiquedanang.id.vn/success
PAYOS_CANCEL_URL=https://luneboutiquedanang.id.vn/payment
PAYOS_WEBHOOK_URL=https://your-backend-domain.com/api/webhooks/payment/payos
PAYOS_TIMEOUT_MS=15000
