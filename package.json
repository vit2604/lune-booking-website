{
  "name": "lune-boutique-booking",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "npm --prefix server run dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm --prefix server run prisma:migrate",
    "db:deploy": "npm --prefix server run prisma:deploy",
    "db:seed": "npm --prefix server run prisma:seed",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "quality:check": "npm run test && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "socket.io-client": "^4.8.1",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
